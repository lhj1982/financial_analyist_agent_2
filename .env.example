# OpenAI API key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use
OPENAI_MODEL=gpt-4o

# Optional: FRED API key for richer credit-spread data
# Get a free one at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: cache TTL in seconds for market data (default 300 = 5 min)
DATA_CACHE_TTL=300
